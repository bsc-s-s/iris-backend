# ─── Database (Supabase PostgreSQL) ───────────────────────
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require

DB_HOST=aws-0-eu-west-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.PROJECT_REF
DB_PASS=your_db_password

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── Groq AI ──────────────────────────────────────────────
GROQ_KEY=gsk_your_groq_api_key_here

# ─── Supabase REST (legacy SPA proxy) ─────────────────────
SB_URL=https://your-project.supabase.co
SB_KEY=your_supabase_anon_key

# ─── Server ───────────────────────────────────────────────
PORT=4000
CORS_ORIGIN=*
FRONTEND_URL=https://tu-frontend.vercel.app
NODE_ENV=development
