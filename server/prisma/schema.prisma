generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  settings  Json?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  facilities  Facility[]
  assessments Assessment[]
  assets      Asset[]
  auditLogs   AuditLog[]
  protocols      SecurityProtocol[]
  simulations    Simulation[]
  subscriptions  Subscription[]
  ssoConfigs     SsoConfig[]
  notificationConfig NotificationConfig?
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  name           String
  role           String    @default("viewer")
  title          String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  createdAssessments Assessment[] @relation("AssessmentCreator")
  auditLogs          AuditLog[]
  refreshTokens      RefreshToken[]

  @@index([organizationId])
  @@index([email])
}

model Facility {
  id             String   @id @default(cuid())
  name           String
  type           String
  address        String?
  country        String?
  city           String?
  riskLevel      String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assessments Assessment[]
  assets      Asset[]

  @@index([organizationId])
}

model Assessment {
  id              String    @id @default(cuid())
  title           String
  status          String    @default("draft")
  version         Int       @default(1)
  methodology     String    @default("iris-v4")
  scores          Json?
  recommendations Json?
  securityPlan    Json?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  facilityId     String?
  facility       Facility?     @relation(fields: [facilityId], references: [id])
  createdById    String
  createdBy      User          @relation("AssessmentCreator", fields: [createdById], references: [id])

  responses        AssessmentResponse[]
  vulnerabilities  Vulnerability[]
  simulations      Simulation[]
  incidents        Incident[]

  @@index([organizationId])
  @@index([facilityId])
  @@index([createdById])
  @@index([status])
}

model AssessmentResponse {
  id           String @id @default(cuid())
  questionId   String
  questionKey  String
  response     Json

  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
}

model Vulnerability {
  id           String   @id @default(cuid())
  category     String
  name         String
  description  String
  severity     String
  status       String   @default("open")
  mitigation   String?
  deadline     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([status])
}

model SecurityProtocol {
  id             String   @id @default(cuid())
  name           String
  description    String
  category       String
  priority       String
  status         String   @default("active")
  implementation Json?
  effectiveness  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([createdAt])
}

model Subscription {
  id                String   @id @default(cuid())
  planId            String
  status            String   @default("incomplete")
  stripeCustomerId  String?  @unique
  stripeSessionId   String?
  stripeSubscriptionId String? @unique
  currentPeriodStart DateTime?
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organizationId String @unique
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([stripeCustomerId])
  @@index([status])
}

model SsoConfig {
  id          String  @id @default(cuid())
  provider    String
  issuer      String
  entryPoint  String
  certificate String?
  clientId    String?
  clientSecret String?
  enabled     Boolean @default(false)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, provider])
  @@index([organizationId])
}

model NotificationConfig {
  id              String   @id @default(cuid())
  emailEnabled    Boolean  @default(false)
  webhookUrl      String?
  slackWebhookUrl String?
  sendAlerts      Boolean  @default(true)
  sendReports     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organizationId String @unique
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}
