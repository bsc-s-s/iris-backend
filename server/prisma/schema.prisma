generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  settings  Json?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // GDPR & Compliance flags
  gdprCompliant       Boolean @default(false)
  iso27001Compliant   Boolean @default(false)
  encryptionEnabled   Boolean @default(false)
  backupEnabled       Boolean @default(false)
  drpEnabled          Boolean @default(false)
  dataRetentionDays   Int     @default(365)
  privacyPolicyUrl    String?
  privacyPolicyVersion String?
  privacyPolicyAcceptedAt DateTime?

  // DPO
  dpoName       String?
  dpoEmail      String?
  dpoPhone      String?
  dpoTitle      String?
  dpoAppointedAt DateTime?

  users       User[]
  facilities  Facility[]
  assessments Assessment[]
  assets      Asset[]
  auditLogs   AuditLog[]
  protocols      SecurityProtocol[]
  simulations    Simulation[]
  subscriptions  Subscription[]
  ssoConfigs     SsoConfig[]
  notificationConfig NotificationConfig?
  apiKeys        ApiKey[]
  webhookEndpoints WebhookEndpoint[]

  // New GDPR/ISO relations
  dpias               DataProcessingRecord[]
  dataExports         DataExport[]
  consentRecords      ConsentRecord[]
  internationalTransfers InternationalTransfer[]
  userConsents        UserConsent[]
  backupConfig        BackupConfig?
  disasterRecoveryPlan DisasterRecoveryPlan?
  cloudProviders      CloudProvider[]
  privacyPolicies     PrivacyPolicy[]
  dataSubjectRequests DataSubjectRequest[]
  encryptionKeys      EncryptionKey[]
  sensitiveFields     SensitiveField[]
  dataRetentionPolicies DataRetentionPolicy[]
  securityEvents      SecurityEvent[]

  // IRIS Organizational Intelligence
  irisScans           IrisScan[]
  irisScores          IrisScore[]
  irisOrgScores       IrisOrgScore[]
  riskSignals         RiskSignal[]
  alerts              Alert[]
  monitorCycles       MonitorCycle[]
  benchmarkData       BenchmarkData[]
  predictions         Prediction[]
  documentInsights    DocumentInsight[]
  reports             Report[]
  invitations         Invitation[]
  activities          Activity[]
  license             License?
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  name           String
  role           String    @default("viewer")
  title          String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  mfaSecret      String?
  mfaEnabled     Boolean   @default(false)
  mfaRecoveryCodes String[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Zero Trust Security
  securityLevel         String   @default("standard") // standard, elevated, maximum
  lastDeviceId          String?
  lockedIp              String?
  allowedCountries      String[]
  failedLoginAttempts   Int      @default(0)
  lockedUntil           DateTime?
  devices               Json?    // [{deviceId, firstSeen, lastSeen, trusted}]

  // GDPR & Privacy
  consentGiven          Boolean @default(false)
  consentGivenAt        DateTime?
  privacyAccepted       Boolean @default(false)
  privacyAcceptedAt     DateTime?
  dataProcessingConsent Boolean @default(false)
  marketingConsent      Boolean @default(false)
  dataProcessingConsentAt DateTime?
  marketingConsentAt    DateTime?

  createdAssessments    Assessment[] @relation("AssessmentCreator")
  auditLogs             AuditLog[]
  refreshTokens         RefreshToken[]
  sessions              UserSession[]
  userConsents          UserConsent[] @relation("UserConsentUser")
  consentRecords        ConsentRecord[] @relation("UserConsentRecord")
  dataSubjectRequests   DataSubjectRequest[] @relation("DataSubjectOwner")
  dsrReviewed           DataSubjectRequest[] @relation("DataSubjectReviewer")
  dpiaCreated           DataProcessingRecord[] @relation("DataProcessingRecordCreator")
  dpiaReviewed          DataProcessingRecord[] @relation("DataProcessingRecordReviewer")
  dataExportRequests    DataExport[] @relation("DataExportRequester")
  securityEvents        SecurityEvent[]

  // IRIS relations
  createdIrisScans      IrisScan[]          @relation("IrisScanCreator")
  acknowledgedSignals   RiskSignal[]        @relation("RiskSignalAcknowledger")
  uploadedDocuments     DocumentInsight[]    @relation("DocumentUploader")
  createdReports        Report[]            @relation("ReportCreator")
  sentInvitations       Invitation[]        @relation("InvitationSender")
  activityLog           Activity[]          @relation("ActivityUser")

  @@index([organizationId])
  @@index([email])
}

model Facility {
  id             String   @id @default(cuid())
  name           String
  type           String
  address        String?
  country        String?
  city           String?
  riskLevel      String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assessments Assessment[]
  assets      Asset[]

  @@index([organizationId])
}

model Area {
  id        String   @id @default(cuid())
  name      String
  nameEn    String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subAreas SubArea[]
}

model SubArea {
  id        String   @id @default(cuid())
  name      String
  nameEn    String?
  order     Int      @default(0)
  areaId    String
  area      Area     @relation(fields: [areaId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions Question[]
}

model Question {
  id        String   @id @default(cuid())
  text      String
  order     Int      @default(0)
  subAreaId String
  subArea   SubArea  @relation(fields: [subAreaId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Assessment {
  id              String    @id @default(cuid())
  title           String
  status          String    @default("draft")
  version         Int       @default(1)
  methodology     String    @default("iris-v5")
  scores          Json?
  recommendations Json?
  securityPlan    Json?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  facilityId     String?
  facility       Facility?     @relation(fields: [facilityId], references: [id])
  createdById    String
  createdBy      User          @relation("AssessmentCreator", fields: [createdById], references: [id])

  selectedSubAreaIds String[] @default([])
  responses          AssessmentResponse[]
  vulnerabilities    Vulnerability[]
  simulations        Simulation[]
  incidents          Incident[]
  protocols          SecurityProtocol[]

  @@index([organizationId])
  @@index([facilityId])
  @@index([createdById])
  @@index([status])
}

model AssessmentResponse {
  id           String @id @default(cuid())
  questionId   String
  response     Json

  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
}

model Vulnerability {
  id           String   @id @default(cuid())
  category     String
  name         String
  description  String
  severity     String
  status       String   @default("open")
  mitigation   String?
  deadline     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([status])
}

model SecurityProtocol {
  id             String   @id @default(cuid())
  name           String
  description    String
  type           String   @default("custom")  // plan_autoproteccion, plan_emergencia, plan_seguridad, protocolo_hipotesis
  category       String
  priority       String
  status         String   @default("active")
  implementation Json?
  effectiveness  String?
  template       String?  // template type used to generate this protocol
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  assessmentId   String?
  assessment     Assessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([createdAt])
  @@index([type])
}

model Simulation {
  id           String    @id @default(cuid())
  type         String
  name         String
  scenario     Json?
  results      Json?
  status       String    @default("pending")
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  organizationId String?
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([assessmentId])
  @@index([type])
}

model Incident {
  id           String    @id @default(cuid())
  title        String
  description  String
  type         String
  severity     String
  status       String    @default("reported")
  impact       Json?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
}

model Asset {
  id             String   @id @default(cuid())
  name           String
  type           String
  value          String
  location       String?
  description    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  facilityId     String?
  facility       Facility?   @relation(fields: [facilityId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([type])
}

model AuditLog {
  id             String   @id @default(cuid())
  action         String
  entity         String
  entityId       String?
  description    String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  sessionId      String?
  result         String   @default("success") // success, failure, denied
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@index([entity])
  @@index([result])
}

model Subscription {
  id                String   @id @default(cuid())
  planId            String
  status            String   @default("incomplete")
  stripeCustomerId  String?  @unique
  stripeSessionId   String?
  stripeSubscriptionId String? @unique
  currentPeriodStart DateTime?
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organizationId String @unique
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([stripeCustomerId])
  @@index([status])
}

model SsoConfig {
  id          String  @id @default(cuid())
  provider    String
  issuer      String
  entryPoint  String
  certificate String?
  clientId    String?
  clientSecret String?
  enabled     Boolean @default(false)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, provider])
  @@index([organizationId])
}

model NotificationConfig {
  id              String   @id @default(cuid())
  emailEnabled    Boolean  @default(false)
  webhookUrl      String?
  slackWebhookUrl String?
  sendAlerts      Boolean  @default(true)
  sendReports     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organizationId String @unique
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model ApiKey {
  id             String   @id @default(cuid())
  name           String
  key            String   @unique
  prefix         String
  scopes         String   @default("read")
  rateLimit      Int      @default(100)
  rateLimitWindow Int     @default(60)
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  enabled        Boolean  @default(true)
  usageCount     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([key])
  @@index([prefix])
}

model WebhookEndpoint {
  id             String   @id @default(cuid())
  name           String
  url            String
  events         String[]
  secret         String
  enabled        Boolean  @default(true)
  retryCount     Int      @default(3)
  timeout        Int      @default(5000)
  lastDeliveryAt DateTime?
  lastStatus     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  deliveryEvents WebhookEvent[]

  @@index([organizationId])
}

model WebhookEvent {
  id             String   @id @default(cuid())
  event          String
  payload        Json
  status         String   @default("pending")
  responseCode   Int?
  responseBody   String?
  attempts       Int      @default(0)
  nextRetryAt    DateTime?
  completedAt    DateTime?
  createdAt      DateTime @default(now())

  endpointId String
  endpoint   WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([status])
  @@index([nextRetryAt])
}

// ================ GDPR & ENTERPRISE COMPLIANCE MODELS ================

/// Data Protection Impact Assessment (DPIA) - GDPR Art 35
model DataProcessingRecord {
  id              String   @id @default(cuid())
  title           String
  description     String
  status          String   @default("draft") // draft, in_review, approved, rejected

  // Data types processed
  dataCategories  Json     // string[] of data categories (personal, sensitive, financial, etc.)
  dataSubjects    Json     // string[] of data subject types (employees, customers, vendors)
  processingPurpose String
  legalBasis      String   // consent, contract, legal_obligation, vital_interests, public_task, legitimate_interests

  // Risk assessment
  riskLevel       String   @default("low") // low, medium, high, critical
  risks           Json?    // [{risk: string, likelihood: string, impact: string, mitigation: string}]
  mitigations     Json?    // [{measure: string, status: string, owner: string}]
  aiImpact        Boolean  @default(false)
  aiDescription   String?

  // Third-party processors
  processors      Json?    // [{name: string, purpose: string, country: string, safeguards: string}]
  internationalTransfers Boolean @default(false)
  transferSafeguards String?

  // Review
  reviewedById    String?
  reviewedBy      User?    @relation("DataProcessingRecordReviewer", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  reviewNotes     String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  createdById     String?
  createdBy       User?    @relation("DataProcessingRecordCreator", fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([status])
  @@index([riskLevel])
}

/// Data Portability Export - GDPR Art 20
model DataExport {
  id             String   @id @default(cuid())
  format         String   @default("json") // json, csv, pdf
  scope          String   // all, assessments, profile, audit, compliance
  status         String   @default("pending") // pending, processing, completed, failed
  fileUrl        String?
  fileSize       Int?
  encryptionKeyId String?
  encryptionKey  EncryptionKey? @relation(fields: [encryptionKeyId], references: [id])
  expiresAt      DateTime?
  completedAt    DateTime?
  failureReason  String?
  createdAt      DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  requestedById  String?
  requestedBy    User?    @relation("DataExportRequester", fields: [requestedById], references: [id])

  @@index([organizationId])
  @@index([status])
}

/// GDPR Consent Record - GDPR Art 7
model ConsentRecord {
  id             String   @id @default(cuid())
  type           String   // data_processing, marketing, cookies, analytics, third_party
  status         String   @default("pending") // pending, granted, withdrawn
  ipAddress      String?
  userAgent      String?
  grantedAt      DateTime?
  withdrawnAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime @default(now())

  userId         String?
  user           User?    @relation("UserConsentRecord", fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([type])
}

/// User Consent Management
model UserConsent {
  id             String   @id @default(cuid())
  type           String   // privacy_policy, terms_of_service, data_processing, marketing, cookies
  version        String
  accepted       Boolean  @default(false)
  acceptedAt     DateTime?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  userId         String
  user           User     @relation("UserConsentUser", fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, type, version])
  @@index([organizationId])
  @@index([userId])
}

/// International Data Transfers - GDPR Art 44-49
model InternationalTransfer {
  id             String   @id @default(cuid())
  thirdParty     String   // name of recipient
  country        String
  purpose        String
  dataCategories Json     // string[]
  legalMechanism String   // adequacy_decision, scc, bcr, consent, derogation
  safeguards     Json?    // [{type: string, description: string}]
  status         String   @default("active") // active, expired, revoked
  riskAssessed   Boolean  @default(false)
  riskLevel      String   @default("medium") // low, medium, high
  expiryDate     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([country])
}

/// Privacy Policy Versioning
model PrivacyPolicy {
  id             String   @id @default(cuid())
  version        String
  title          String
  content        String   // Markdown/content of the policy
  effectiveDate  DateTime
  required       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, version])
  @@index([organizationId])
}

/// Data Subject Request (Right to be Forgotten, Access, Rectification, etc.)
model DataSubjectRequest {
  id             String   @id @default(cuid())
  type           String   // access, rectification, erasure, restriction, portability, objection
  status         String   @default("pending") // pending, processing, completed, rejected
  description    String?
  dataIdentified Json?    // {assessments: int, auditLogs: int, ...}
  completedAt    DateTime?
  rejectionReason String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId         String
  user           User     @relation("DataSubjectOwner", fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  reviewedById   String?
  reviewedBy     User?    @relation("DataSubjectReviewer", fields: [reviewedById], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([type])
  @@index([status])
}

// ================ IRIS™ ORGANIZATIONAL INTELLIGENCE PLATFORM ================

/// IRIS Scan — Conversational adaptive assessment session
model IrisScan {
  id             String   @id @default(cuid())
  title          String
  status         String   @default("in_progress") // in_progress, completed, cancelled
  phase          String   @default("blind_spot") // blind_spot, protocol_erosion, overconfidence, key_person, cultural_degradation, governance_weakness, operational_fragility, knowledge_concentration, strategic_misalignment, resilience_capacity
  currentQuestion Int     @default(0)
  totalQuestions  Int     @default(100)
  startedAt      DateTime @default(now())
  completedAt    DateTime?
  metadata       Json?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String?
  createdBy      User?    @relation("IrisScanCreator", fields: [createdById], references: [id])
  responses      IrisResponse[]
  scores         IrisScore[]
  signals        RiskSignal[]
  monitorCycles  MonitorCycle[]
  @@index([organizationId])
  @@index([status])
}

/// IRIS Response — Individual answer within a scan
model IrisResponse {
  id         String   @id @default(cuid())
  questionId String
  question   IrisQuestion @relation(fields: [questionId], references: [id])
  response   Json     // { value: 1-5 | text: string, latency: number, hesitation: number, corrections: number }
  latency    Int?     // ms to respond
  hesitation Int?     // number of pauses
  corrections Int?    // times answer was changed
  createdAt  DateTime @default(now())
  scanId     String
  scan       IrisScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  @@index([scanId])
}

/// IRIS Question — Dynamic, context-aware questions
model IrisQuestion {
  id          String   @id @default(cuid())
  text        String
  category    String   // blind_spot, protocol_erosion, overconfidence, key_person, cultural_degradation, governance_weakness, operational_fragility, knowledge_concentration, strategic_misalignment, resilience_capacity
  subCategory String?
  weight      Float    @default(1.0)
  depth       Int      @default(1) // 1=surface, 2=probing, 3=deep
  adaptive    Boolean  @default(true) // adapts based on previous responses
  condition   Json?    // { minScore?: number, maxScore?: number, dependsOn?: string }
  responses   IrisResponse[]
  @@index([category])
}

/// IRIS Score — Multi-dimensional scoring snapshot
model IrisScore {
  id         String   @id @default(cuid())
  dimension  String   // anticipation, resilience, exposure, invisibility, dependency, culture, governance, fragility, operational_health, strategic_alignment
  value      Float
  weight     Float    @default(1.0)
  trend      String   @default("stable") // improving, stable, declining
  delta      Float?   // change from previous score
  calculatedAt DateTime @default(now())
  scanId     String?
  scan       IrisScan? @relation(fields: [scanId], references: [id])
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id])
  @@index([organizationId, dimension])
  @@index([scanId])
}

/// IRIS Organizational Intelligence Score™ — Main composite score
model IrisOrgScore {
  id              String   @id @default(cuid())
  overallScore    Float    // 0-100
  classification  String   // critical, high_risk, moderate_risk, stable, resilient
  anticipation    Float
  resilience      Float
  exposure        Float
  invisibility    Float
  dependency      Float
  culture         Float
  governance      Float
  fragility       Float
  operationalHealth Float
  strategicAlignment Float
  confidence      Float    @default(0.85)
  calculatedAt    DateTime @default(now())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  @@index([organizationId])
  @@index([calculatedAt])
  @@index([overallScore])
}

/// RiskSignal — Detected organizational risk signals
model RiskSignal {
  id              String   @id @default(cuid())
  type            String   // pattern, behavioral, organizational
  category        String   // inconsistency, contradiction, anomaly, weak_signal, deterioration
  title           String
  description     String
  severity        String   @default("medium") // critical, high, medium, low, info
  confidence      Float    @default(0.7)
  source          String   // scan, monitor, ai_engine, document, benchmark
  metadata        Json?
  detectedAt      DateTime @default(now())
  acknowledgedAt  DateTime?
  acknowledgedById String?
  acknowledgedBy  User?    @relation("RiskSignalAcknowledger", fields: [acknowledgedById], references: [id])
  scanId          String?
  scan            IrisScan? @relation(fields: [scanId], references: [id])
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  alerts          Alert[]
  @@index([organizationId])
  @@index([type])
  @@index([severity])
  @@index([scanId])
}

/// Alert — Intelligent, context-aware alert
model Alert {
  id              String    @id @default(cuid())
  title           String
  message         String
  severity        String    @default("medium") // critical, high, medium, low
  category        String    // resilience, dependency, protocol, cultural, governance
  source          String    // monitor, scan, predict, benchmark
  metric          String?   // the score field that triggered the alert
  previousValue   Float?
  currentValue    Float?
  threshold       Float?
  read            Boolean   @default(false)
  dismissedAt     DateTime?
  createdAt       DateTime  @default(now())
  signalId        String?
  signal          RiskSignal? @relation(fields: [signalId], references: [id])
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  @@index([organizationId])
  @@index([severity])
  @@index([createdAt])
  @@index([read])
}

/// MonitorCycle — Continuous monitoring schedule
model MonitorCycle {
  id              String    @id @default(cuid())
  frequency       String    // weekly, monthly, quarterly
  status          String    @default("pending") // pending, running, completed, failed
  startedAt       DateTime?
  completedAt     DateTime?
  scores          Json?     // snapshot of all scores at this cycle
  signalsCount    Int       @default(0)
  alertsGenerated Int       @default(0)
  metadata        Json?
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  scanId          String?
  scan            IrisScan? @relation(fields: [scanId], references: [id])
  @@index([organizationId])
  @@index([frequency])
  @@index([status])
}

/// BenchmarkData — Cross-organizational benchmark records
model BenchmarkData {
  id              String   @id @default(cuid())
  overallScore    Float
  industry        String?
  companySize     String?  // small, medium, large, enterprise
  employeeCount   Int?
  revenue        String?
  region          String?
  scores          Json     // all dimension scores
  calculatedAt    DateTime @default(now())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  @@index([organizationId])
  @@index([industry])
  @@index([overallScore])
}

/// Prediction — IRIS predictive model output
model Prediction {
  id              String   @id @default(cuid())
  model           String   // operational_crisis, talent_loss, knowledge_collapse, governance_failure, cultural_failure, burnout
  probability     Float    // 0-1
  impact          String   // critical, high, medium, low
  timeHorizon     String   // 30d, 60d, 90d, 6m, 12m
  causalFactors   Json?
  recommendations Json?
  score           Float?   // prediction confidence score
  calculatedAt    DateTime @default(now())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  @@index([organizationId])
  @@index([model])
  @@index([probability])
}

/// DocumentInsight — AI extraction from uploaded documents
model DocumentInsight {
  id              String   @id @default(cuid())
  fileName        String
  fileType        String   // pdf, docx, xlsx
  fileSize        Int?
  content         String?  // extracted text
  summary         String?
  riskSignals     Json?    // extracted risk signals
  keyFindings     Json?
  recommendations Json?
  processedAt     DateTime @default(now())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  uploadedById    String?
  uploadedBy      User?    @relation("DocumentUploader", fields: [uploadedById], references: [id])
  @@index([organizationId])
}

/// Report — Generated executive report
model Report {
  id              String   @id @default(cuid())
  title           String
  type            String   // executive, board, compliance, risk_assessment
  format          String   // json, pdf, docx, pptx
  status          String   @default("draft") // draft, generating, completed, failed
  content         Json?    // full report data
  sections        Json?    // array of section configs
  generatedAt     DateTime @default(now())
  completedAt     DateTime?
  fileUrl         String?
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  createdById     String?
  createdBy       User?    @relation("ReportCreator", fields: [createdById], references: [id])
  @@index([organizationId])
  @@index([type])
}

/// Invitation — Invite-only access control
model Invitation {
  id              String    @id @default(cuid())
  email           String
  token           String    @unique
  role            String    @default("member")
  status          String    @default("pending") // pending, accepted, expired, revoked
  expiresAt       DateTime
  acceptedAt      DateTime?
  invitedById     String?
  invitedBy       User?     @relation("InvitationSender", fields: [invitedById], references: [id])
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  createdAt       DateTime  @default(now())
  @@index([email])
  @@index([token])
  @@index([status])
}

/// Activity — Organizational timeline event
model Activity {
  id              String   @id @default(cuid())
  type            String   // scan_completed, alert_triggered, score_changed, report_generated, action_taken, risk_detected, benchmark_updated, prediction_made
  title           String
  description     String?
  severity        String   @default("info") // critical, high, medium, low, info
  metadata        Json?
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  userId          String?
  user            User?    @relation("ActivityUser", fields: [userId], references: [id])
  createdAt       DateTime @default(now())
  @@index([organizationId])
  @@index([type])
  @@index([createdAt])
}

/// License — SaaS subscription/license management
model License {
  id              String   @id @default(cuid())
  plan            String   // starter, professional, enterprise, enterprise_plus
  status          String   @default("active") // active, suspended, cancelled, expired
  maxUsers        Int      @default(10)
  maxAssessments  Int      @default(50)
  maxScans        Int      @default(10)
  benchmarking    Boolean  @default(false)
  monitoring      Boolean  @default(false)
  aiEnabled       Boolean  @default(true)
  apiAccess       Boolean  @default(false)
  customBranding  Boolean  @default(false)
  supportLevel    String   @default("standard") // standard, priority, dedicated
  startsAt        DateTime @default(now())
  expiresAt       DateTime?
  cancelledAt     DateTime?
  organizationId  String   @unique
  organization    Organization @relation(fields: [organizationId], references: [id])
  @@index([plan])
  @@index([status])
}

// ================ ISO 27001 MODELS ================

/// User Sessions for session management & revocation
model UserSession {
  id             String   @id @default(cuid())
  token          String   @unique
  refreshTokenId String?
  ipAddress      String?
  userAgent      String?
  deviceInfo     String?
  location       String?
  isActive       Boolean  @default(true)
  lastActivityAt DateTime @default(now())
  expiresAt      DateTime
  revokedAt      DateTime?
  revokedReason  String?
  createdAt      DateTime @default(now())

  userId         String
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([token])
  @@index([isActive])
}

/// Backup Configuration - ISO 27001 A.12.3
model BackupConfig {
  id                  String   @id @default(cuid())
  enabled             Boolean  @default(true)
  frequency           String   @default("daily") // hourly, daily, weekly, monthly
  retentionDays       Int      @default(30)
  encryptionEnabled   Boolean  @default(true)
  encryptionAlgorithm String   @default("AES-256-GCM")
  storageLocation     String   // s3, gcs, azure, local
  storageBucket       String?
  storageRegion       String?
  lastBackupAt        DateTime?
  lastBackupSize      Int?
  lastBackupStatus    String?  // success, failed, in_progress
  nextBackupAt        DateTime?
  backupTypes         Json     // ["full", "incremental", "differential"]
  pointInTimeRecovery Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organizationId      String   @unique
  organization        Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

/// Disaster Recovery Plan - ISO 27001 A.17
model DisasterRecoveryPlan {
  id                 String   @id @default(cuid())
  name               String
  description        String?
  status             String   @default("draft") // draft, reviewed, approved, tested
  rto                Int      // Recovery Time Objective (minutes)
  rpo                Int      // Recovery Point Objective (minutes)
  priority           String   @default("medium") // critical, high, medium, low
  scope              Json     // {systems: string[], data: string[], locations: string[]}
  procedures         Json?    // [{step: int, action: string, owner: string, duration: string}]
  contacts           Json?    // [{name: string, role: string, phone: string, email: string}]
  lastTestedAt       DateTime?
  testResults        Json?
  approvedById       String?
  approvedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organizationId     String   @unique
  organization       Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

/// Cloud Provider Registry - ISO 27001 A.11 (Physical Security)
model CloudProvider {
  id                String   @id @default(cuid())
  name              String
  providerType      String   // iaas, paas, saas, hosting, cdn, email, ai
  description       String?
  serviceUrl        String?
  dataCenters       Json?    // [{location: string, country: string, region: string}]
  certifications    String[] // ["ISO27001", "SOC2", "GDPR", "PCI-DSS", "FedRAMP"]
  complianceLevel   String   @default("none") // none, basic, medium, high, certified
  euDataBoundary    Boolean  @default(false) // data stays within EU
  contractSigned    Boolean  @default(false)
  contractFileUrl   String?
  slaUrl            String?
  dpiaRequired      Boolean  @default(false)
  dpiaCompleted     Boolean  @default(false)
  status            String   @default("active") // active, inactive, pending_review, terminated
  riskLevel         String   @default("medium") // low, medium, high, critical
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([providerType])
}

/// Encryption Key Management
model EncryptionKey {
  id             String   @id @default(cuid())
  name           String
  algorithm      String   @default("AES-256-GCM")
  keyId          String   @unique
  publicKey      String?
  status         String   @default("active") // active, expired, revoked, rotated
  purpose        String   // data-at-rest, field-level, backup, transport, signing
  expiresAt      DateTime?
  rotatedAt      DateTime?
  rotatedFromId  String?  // previous key if rotated
  createdAt      DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  dataExports    DataExport[]

  @@index([organizationId])
  @@index([status])
  @@index([purpose])
}

/// Sensitive/PII Field Registry
model SensitiveField {
  id             String   @id @default(cuid())
  entity         String   // user, assessment, facility, etc.
  field          String   // email, name, address, notes, etc.
  dataType       String   // pii, sensitive, financial, health, biometric
  classification String   // public, internal, confidential, restricted
  encryption     Boolean  @default(false)
  masking        Boolean  @default(false)
  retentionDays  Int?
  justification  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, entity, field])
  @@index([organizationId])
  @@index([dataType])
}

/// Data Retention Policy
model DataRetentionPolicy {
  id             String   @id @default(cuid())
  dataCategory   String   // audit_logs, assessments, user_data, consent, backups, reports
  retentionDays  Int
  action         String   @default("delete") // delete, anonymize, archive
  legalHold      Boolean  @default(false)
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, dataCategory])
  @@index([organizationId])
}

/// Immutable Security Event Log (Zero Trust blockchain-style audit)
model SecurityEvent {
  id             String   @id @default(cuid())
  type           String   // login, logout, failed_login, mfa_attempt, device_change, ip_change, geo_anomaly, session_hijack, account_lockout, access_denied, anomaly_blocked, anomaly_warning, session_revoked, user_locked, user_unlocked
  severity       String   @default("info") // info, warning, critical
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  ipAddress      String?
  deviceId       String?
  country        String?
  userAgent      String?
  metadata       Json?
  hash           String   @unique
  previousHash   String?
  timestamp      DateTime @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([type])
  @@index([severity])
  @@index([timestamp])
  @@index([hash])
}
