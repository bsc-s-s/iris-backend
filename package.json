{
  "name": "iris-enterprise-monorepo",
  "version": "5.0.0",
  "private": true,
  "description": "IRIS Enterprise - Arquitectura de Riesgo y Seguridad Integral",
  "scripts": {
    "start": "node server/start.js",
    "legacy": "node server.js",
    "server:dev": "cd server && npm run start:dev",
    "server:build": "cd server && npm run build",
    "server:start": "cd server && npm run start:prod",
    "web:dev": "cd web && npm run dev",
    "web:build": "cd web && npm run build",
    "web:start": "cd web && npm run start",
    "db:push": "cd server && npx prisma db push",
    "db:generate": "cd server && npx prisma generate"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5"
  }
}
